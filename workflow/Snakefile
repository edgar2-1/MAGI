# =============================================================================
# MAGI — Multi-kingdom Analysis of Genomic Interactions
# Main Snakemake Workflow
# =============================================================================
#
# Pipeline flow:
#   1. QC          — Quality filtering, adapter trimming, host decontamination
#   2. Assembly    — (Optional) Metagenomic assembly with metaflye or hifiasm-meta
#   3. Classify    — Taxonomic classification of bacteriome, mycobiome, and virome
#                    These three classification steps run in parallel.
#   4. Unifier     — Merge and normalize abundance tables across all three kingdoms
#   5. Analysis    — Co-occurrence networks, alpha/beta diversity, differential abundance
#   6. Metadata    — Metadata correlation via random forest feature importance
#   7. Reporting   — Generate interactive dashboard and static figures
# =============================================================================

configfile: "config/default_config.yaml"

import glob as _glob
import os as _os

def get_samples():
    """Discover sample names from the configured reads glob pattern."""
    reads_pattern = config["input"]["reads"]
    # Convert glob pattern to list of files
    files = sorted(_glob.glob(reads_pattern))
    # Extract sample names from filenames
    samples = [_os.path.splitext(_os.path.basename(f))[0] for f in files]
    # Strip .fastq suffix if double-extension (.fastq.gz)
    samples = [s.replace(".fastq", "") for s in samples]
    if not samples:
        # Fallback: try glob_wildcards pattern
        import re
        # Convert shell glob to snakemake pattern
        pattern = reads_pattern.replace("*", "{sample}")
        try:
            from snakemake.io import glob_wildcards
            samples = glob_wildcards(pattern).sample
        except Exception:
            pass
    return samples

SAMPLES = get_samples()

def get_reads_dir():
    """Get the directory containing raw reads from config."""
    import os
    return os.path.dirname(config["input"]["reads"])

READS_DIR = get_reads_dir()


# ---------------------------------------------------------------------------
# Include modular rule files
# ---------------------------------------------------------------------------
include: "rules/qc.smk"
include: "rules/assembly.smk"
include: "rules/classify.smk"
include: "rules/unifier.smk"
include: "rules/analysis.smk"
include: "rules/metadata.smk"
include: "rules/reporting.smk"


# ---------------------------------------------------------------------------
# Helper: build the list of expected final outputs
# ---------------------------------------------------------------------------
def get_final_outputs():
    """Return the list of target files the pipeline must produce."""
    outputs = []

    # Reporting outputs are always requested
    outdir = config["project"]["output_dir"]
    outputs.append(f"{outdir}/report/dashboard.html")
    outputs.append(f"{outdir}/report/figures_done.flag")

    return outputs


# ---------------------------------------------------------------------------
# Default target rule — requests all final reporting outputs
# ---------------------------------------------------------------------------
rule all:
    input:
        get_final_outputs(),
